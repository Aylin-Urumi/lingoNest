<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LingoNest.ViewModels"
        x:Class="LingoNest.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="LingoNest"
        Width="800" Height="600"
        MinWidth="600" MinHeight="400">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto" Margin="20">

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="🌐 LingoNest"
                       FontSize="28"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Multilingual Dictionary and Translator"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       Opacity="0.6"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,*" RowDefinitions="Auto,Auto,*">

            <!-- Source Language Picker -->
            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">
                <TextBlock Text="From" Margin="0,0,0,4" Opacity="0.7"/>
                <ComboBox ItemsSource="{Binding Languages}"
                          SelectedItem="{Binding SelectedSourceLanguage}"
                          HorizontalAlignment="Stretch"/>
            </StackPanel>

            <!-- Arrow -->
            <TextBlock Grid.Row="0" Grid.Column="1"
                       Text="→"
                       FontSize="24"
                       VerticalAlignment="Bottom"
                       Margin="10,0,10,10"/>

            <!-- Target Language Picker -->
            <StackPanel Grid.Row="0" Grid.Column="2" Margin="10,0,0,10">
                <TextBlock Text="To" Margin="0,0,0,4" Opacity="0.7"/>
                <ComboBox ItemsSource="{Binding Languages}"
                          SelectedItem="{Binding SelectedTargetLanguage}"
                          HorizontalAlignment="Stretch"/>
            </StackPanel>

            <!-- Input Box -->
            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,10">
                <TextBlock Text="Enter text" Margin="0,0,0,4" Opacity="0.7"/>
                <TextBox Text="{Binding InputText}"
                         Height="120"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Watermark="Type something to translate..."/>
            </StackPanel>

            <!-- Translate Button -->
            <Button Grid.Row="1" Grid.Column="1"
                    Content="→"
                    FontSize="20"
                    Width="50" Height="50"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    IsEnabled="{Binding !IsLoading}"
                    Click="OnTranslateClicked"/>

            <!-- Output Box -->
            <StackPanel Grid.Row="1" Grid.Column="2" Margin="10,0,0,10">
                <TextBlock Text="Translation" Margin="0,0,0,4" Opacity="0.7"/>
                <TextBox Text="{Binding TranslatedText}"
                         Height="120"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         Watermark="Translation will appear here..."/>
            </StackPanel>

            <!-- History -->
            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,10,0,0">
                <TextBlock Text="Translation History"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>
                <ListBox ItemsSource="{Binding TranslationHistory}"
                         MaxHeight="150">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding Word}" FontWeight="SemiBold"/>
                                <TextBlock Text="→" Opacity="0.5"/>
                                <TextBlock Text="{Binding TranslatedText}"/>
                                <TextBlock Text="{Binding SourceLanguage}" Opacity="0.4" FontSize="11"/>
                                <TextBlock Text="→" Opacity="0.4" FontSize="11"/>
                                <TextBlock Text="{Binding TargetLanguage}" Opacity="0.4" FontSize="11"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>

        </Grid>

        <!-- Status Bar -->
        <TextBlock Grid.Row="2"
                   Text="{Binding StatusMessage}"
                   Opacity="0.6"
                   FontSize="12"
                   Margin="0,10,0,0"
                   HorizontalAlignment="Center"/>

    </Grid>
</Window>